{
  "name": "spirit-of-life",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "check-types": "turbo check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.15.0",
      "eslint>minimatch": "10.2.5",
      "eslint-plugin-import>minimatch": "3.1.5",
      "eslint-plugin-react>minimatch": "3.1.5",
      "flatted": "^3.4.2",
      "follow-redirects": "^1.16.0",
      "js-yaml": "^3.14.2",
      "lodash-es": "^4.18.0",
      "postcss": "^8.5.10",
      "prismjs": "^1.30.0"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
